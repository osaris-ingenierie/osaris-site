# ─────────────────────────────────────────────────────────────
# Configuration EmailJS — formulaire de contact
# Copier ce fichier en .env.local et renseigner vos valeurs.
# Ces clés sont publiques par conception (préfixe NEXT_PUBLIC_).
# https://dashboard.emailjs.com
# ─────────────────────────────────────────────────────────────

# ID du service e-mail (Email Services > votre service)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=

# ID du template (Email Templates > votre template)
# Variables attendues dans le template :
#   {{from_prenom}} {{from_nom}} {{from_societe}}
#   {{from_email}} {{from_tel}} {{mission_type}} {{message}} {{to_email}}
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=

# Clé publique (Account > General > Public Key)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
